{
  "name": "price-tag-printer",
  "version": "1.0.0",
  "description": "Lightweight Electron app for printing TSPL price tags",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently \"vite\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"sleep 2 && NODE_ENV=development electron .\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build && tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "type-check": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit"
  },
  "keywords": ["electron", "price-tag", "printer", "tspl"],
  "author": {
    "name": "Ergashev Boburmirzo",
    "email": "ergashevboburmirzo815@gmail.com"
  },
  "homepage": "https://github.com/Bobur815/price-tag-printer-linux",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.8",
    "react-i18next": "^14.0.0",
    "i18next": "^23.7.0",
    "lucide-react": "^0.303.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/styled-components": "^5.1.34",
    "@types/node": "^20.10.6",
    "vite": "^5.0.10",
    "@vitejs/plugin-react": "^4.2.1",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2"
  },
  "build": {
    "appId": "uz.bobur.price-tag-printer",
    "productName": "Price Tag Printer",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
